---
import '../styles/global.css';
interface Props { lang: 'en' | 'ko'; title: string; description: string; }
const { lang, title, description } = Astro.props;
const site = 'https://siliconscope.calidalab.ai';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={lang === 'ko' ? `${site}/ko/` : `${site}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:image" content={`${site}/og.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- Type system shared with the Spectalo/SpectaLing sites: Bricolage Grotesque (display) + Inter (body). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600&display=swap"
    />
    <!-- Cloudflare Web Analytics (cookieless, no PII, no cross-site tracking) — website only; the app sends no telemetry. -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "0cccd91a3d5f40648f6e9678558bb04e"}'></script>
  </head>
  <body>
    <slot />
  </body>
</html>
